<!DOCTYPE html>
<html class="dark" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Restaurant Registration | Restaurant Suite</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link href="styles.css" rel="stylesheet" />
    <script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              primary: "#f28c28",
              "background-light": "#f6f2ea",
              "background-dark": "#0f1a18",
              "neutral-gold": "#33423f",
              "muted-gold": "#9fb0a8",
              "surface-dark": "#1a2b27"
            },
            fontFamily: {
              display: ["Manrope", "sans-serif"],
              serif: ["Playfair Display", "serif"]
            },
            borderRadius: {
              DEFAULT: "0.5rem",
              lg: "1rem",
              xl: "1.5rem",
              full: "9999px"
            }
          }
        }
      };
    </script>
  </head>
  <body class="bg-gradient-to-b from-[#152421] via-[#0f1a18] to-[#0b1412] font-display text-slate-100 min-h-screen">
    <div class="relative flex min-h-screen w-full flex-col overflow-x-hidden">
      <div class="pointer-events-none absolute -top-40 right-0 h-96 w-96 rounded-full bg-primary/20 blur-3xl"></div>
      <div class="pointer-events-none absolute -bottom-24 left-0 h-96 w-96 rounded-full bg-primary/10 blur-3xl"></div>

      <header class="mx-auto flex w-full max-w-6xl items-center justify-between px-6 py-6">
        <div class="flex items-center gap-3 text-primary">
          <span class="material-symbols-outlined text-3xl">restaurant</span>
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.3em] text-primary/70">Registration</p>
            <h1 class="text-2xl font-serif font-bold text-slate-100">Restaurant Onboarding</h1>
          </div>
        </div>
      </header>

      <main class="flex flex-1 items-center justify-center px-6 pb-16">
        <div
          class="w-full max-w-6xl overflow-hidden rounded-3xl border border-primary/20 bg-[#152421]/85 shadow-[0_25px_60px_rgba(0,0,0,0.6)] backdrop-blur md:grid md:grid-cols-[1.1fr_1fr]"
        >
          <div class="relative hidden flex-col justify-between overflow-hidden p-10 md:flex">
            <div class="absolute inset-0 bg-gradient-to-br from-black/85 via-black/60 to-transparent"></div>
            <div
              class="absolute inset-0 bg-cover bg-center opacity-90"
              id="register-hero-bg"
              style='background-image: url("/images/ui/premium-hero-dark.jpg");'
            ></div>
            <div class="relative z-10">
              <span
                class="mb-3 inline-flex items-center rounded-full border border-primary/30 bg-primary/10 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-primary"
              >
                Launch Ready
              </span>
              <h2 class="text-3xl font-serif leading-tight text-white">Bring your dining experience online.</h2>
              <p class="mt-4 text-sm text-muted-gold">
                Create your restaurant profile, menus, and ordering flow in minutes.
              </p>
            </div>
            <div class="relative z-10 mt-12 rounded-2xl border border-primary/20 bg-primary/5 p-4 text-xs text-muted-gold">
              Tip: Add at least 10 menu items after signup for a rich guest experience.
            </div>
          </div>

          <div class="flex flex-col justify-center gap-6 p-8 md:p-12">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.3em] text-primary/70">Quick Start</p>
              <h3 class="mt-2 text-2xl font-serif font-bold">Choose your next step</h3>
              <p class="mt-2 text-sm text-muted-gold">Only two options are shown here. Admin details appear after you choose.</p>
            </div>
            <div class="rounded-xl border border-primary/20 bg-primary/5 p-4">
              <div class="flex flex-col gap-3">
                <a
                  class="flex h-12 items-center justify-center rounded-lg bg-primary text-base font-bold text-background-dark shadow-lg shadow-primary/20 transition-all hover:brightness-110"
                  href="../menu_section/code.html"
                >
                  <span class="material-symbols-outlined mr-2">restaurant_menu</span>
                  Customer Get Started
                </a>
                <button
                  class="flex h-12 items-center justify-center rounded-lg border border-primary/40 text-base font-semibold text-primary transition-all hover:bg-primary hover:text-background-dark"
                  id="admin-modal-open"
                  type="button"
                  aria-expanded="false"
                  aria-controls="admin-choice-modal"
                >
                  <span class="material-symbols-outlined mr-2">admin_panel_settings</span>
                  Admin Login
                </button>
              </div>
            </div>

            <div class="hidden" id="admin-details">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.3em] text-primary/70">Restaurant Details</p>
                <h3 class="mt-2 text-2xl font-serif font-bold">Create Your Restaurant Profile</h3>
                <p class="mt-2 text-sm text-muted-gold">Fill in the basics to get your ordering flow live.</p>
              </div>

              <form class="mt-6 grid grid-cols-1 gap-4 md:grid-cols-2" id="registration-form">
              <label class="flex flex-col gap-2 text-sm font-semibold text-slate-100">
                Restaurant Name
                <input
                  class="h-12 rounded-lg border border-neutral-gold bg-surface-dark px-4 text-base font-normal text-white placeholder:text-muted-gold/40 focus:border-primary focus:outline-0 focus:ring-1 focus:ring-primary"
                  placeholder="e.g. Hush Modern"
                  type="text"
                  required
                />
              </label>
              <label class="flex flex-col gap-2 text-sm font-semibold text-slate-100">
                Owner Name
                <input
                  class="h-12 rounded-lg border border-neutral-gold bg-surface-dark px-4 text-base font-normal text-white placeholder:text-muted-gold/40 focus:border-primary focus:outline-0 focus:ring-1 focus:ring-primary"
                  placeholder="Full name"
                  type="text"
                  required
                />
              </label>
              <label class="flex flex-col gap-2 text-sm font-semibold text-slate-100">
                Email
                <input
                  class="h-12 rounded-lg border border-neutral-gold bg-surface-dark px-4 text-base font-normal text-white placeholder:text-muted-gold/40 focus:border-primary focus:outline-0 focus:ring-1 focus:ring-primary"
                  placeholder="owner@restaurant.com"
                  id="register-email"
                  type="email"
                  autocomplete="email"
                  required
                />
              </label>
              <label class="flex flex-col gap-2 text-sm font-semibold text-slate-100">
                Phone
                <input
                  class="h-12 rounded-lg border border-neutral-gold bg-surface-dark px-4 text-base font-normal text-white placeholder:text-muted-gold/40 focus:border-primary focus:outline-0 focus:ring-1 focus:ring-primary"
                  placeholder="+91 9xxxx xxxxx"
                  id="register-phone"
                  type="tel"
                  inputmode="numeric"
                  pattern="[0-9]{10}"
                  maxlength="10"
                  minlength="10"
                  autocomplete="tel"
                  required
                />
              </label>
              <label class="flex flex-col gap-2 text-sm font-semibold text-slate-100">
                Owner Access Key
                <input
                  class="h-12 rounded-lg border border-neutral-gold bg-surface-dark px-4 text-base font-normal text-white placeholder:text-muted-gold/40 focus:border-primary focus:outline-0 focus:ring-1 focus:ring-primary"
                  id="register-access-key"
                  placeholder="e.g. HAVEN-ADMIN-01"
                  required
                />
              </label>
              <label class="flex flex-col gap-2 text-sm font-semibold text-slate-100">
                City
                <input
                  class="h-12 rounded-lg border border-neutral-gold bg-surface-dark px-4 text-base font-normal text-white placeholder:text-muted-gold/40 focus:border-primary focus:outline-0 focus:ring-1 focus:ring-primary"
                  placeholder="Ahmedabad"
                  type="text"
                  required
                />
              </label>
              <label class="flex flex-col gap-2 text-sm font-semibold text-slate-100">
                Cuisine Type
                <select
                  class="h-12 rounded-lg border border-neutral-gold bg-surface-dark px-4 text-base font-normal text-white focus:border-primary focus:outline-0 focus:ring-1 focus:ring-primary"
                >
                  <option>Modern Indian</option>
                  <option>Pan Asian</option>
                  <option>Italian</option>
                  <option>South Indian</option>
                  <option>Multi Cuisine</option>
                </select>
              </label>
              <label class="flex flex-col gap-2 text-sm font-semibold text-slate-100">
                Seating Capacity
                <input
                  class="h-12 rounded-lg border border-neutral-gold bg-surface-dark px-4 text-base font-normal text-white placeholder:text-muted-gold/40 focus:border-primary focus:outline-0 focus:ring-1 focus:ring-primary"
                  placeholder="e.g. 80"
                  type="number"
                  min="1"
                />
              </label>
              <label class="flex flex-col gap-2 text-sm font-semibold text-slate-100">
                Password
                <input
                  class="h-12 rounded-lg border border-neutral-gold bg-surface-dark px-4 text-base font-normal text-white placeholder:text-muted-gold/40 focus:border-primary focus:outline-0 focus:ring-1 focus:ring-primary"
                  placeholder="Create a password"
                  type="password"
                  required
                />
              </label>
              <label class="flex flex-col gap-2 text-sm font-semibold text-slate-100">
                Confirm Password
                <input
                  class="h-12 rounded-lg border border-neutral-gold bg-surface-dark px-4 text-base font-normal text-white placeholder:text-muted-gold/40 focus:border-primary focus:outline-0 focus:ring-1 focus:ring-primary"
                  placeholder="Re-enter password"
                  type="password"
                  required
                />
              </label>
              <label class="flex items-center gap-2 text-sm font-semibold text-muted-gold md:col-span-2">
                <input class="h-4 w-4 rounded border-neutral-gold bg-surface-dark text-primary focus:ring-primary" type="checkbox" />
                I agree to the platform terms and menu guidelines
              </label>
              <div class="flex flex-col gap-3 md:col-span-2">
                <button
                  class="flex h-12 w-full items-center justify-center rounded-lg bg-primary text-base font-bold text-background-dark shadow-lg shadow-primary/20 transition-all hover:brightness-110"
                  type="submit"
                >
                  <span class="material-symbols-outlined mr-2">app_registration</span>
                  Create Restaurant Profile
                </button>
                <a class="text-xs text-muted-gold hover:text-primary" href="../admin_portal/code.html">
                  Already registered? Go to the admin portal
                </a>
              </div>
            </form>
          </div>
        </div>
      </div>
      </main>
      <div class="fixed inset-0 z-50 hidden" id="admin-choice-modal" aria-hidden="true">
        <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" data-admin-close></div>
        <div
          class="relative mx-auto my-10 w-[min(92vw,420px)] rounded-2xl border border-primary/30 bg-[#152421] p-6 shadow-2xl"
        >
          <div class="flex items-center justify-between">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.3em] text-primary/70">Admin Access</p>
              <h3 class="mt-1 text-xl font-serif font-bold text-slate-100">Choose Admin Mode</h3>
            </div>
            <button
              class="flex size-9 items-center justify-center rounded-full border border-primary/30 text-primary transition-all hover:bg-primary hover:text-background-dark"
              id="admin-modal-close"
              type="button"
            >
              <span class="material-symbols-outlined text-base">close</span>
            </button>
          </div>
          <p class="mt-3 text-sm text-muted-gold">Pick the option that fits your restaurant status.</p>
          <div class="mt-5 grid grid-cols-1 gap-3">
            <button
              class="flex h-11 items-center justify-center rounded-lg bg-primary text-sm font-bold text-background-dark shadow-lg shadow-primary/30 transition-all hover:brightness-110"
              id="admin-new-btn"
              type="button"
            >
              <span class="material-symbols-outlined mr-2 text-base">app_registration</span>
              New Restaurant Setup
            </button>
            <a
              class="flex h-11 items-center justify-center rounded-lg border border-primary/30 text-sm font-semibold text-primary transition-all hover:bg-primary hover:text-background-dark"
              href="../admin_portal/code.html"
            >
              <span class="material-symbols-outlined mr-2 text-base">verified_user</span>
              Existing Owner Login
            </a>
          </div>
        </div>
      </div>
    </div>
    <script>
      const adminModal = document.getElementById("admin-choice-modal");
      const adminModalOpen = document.getElementById("admin-modal-open");
      const adminModalClose = document.getElementById("admin-modal-close");
      const adminNewBtn = document.getElementById("admin-new-btn");
      const adminDetails = document.getElementById("admin-details");

      const openAdminModal = () => {
        if (!adminModal) return;
        adminModal.classList.remove("hidden");
        adminModal.setAttribute("aria-hidden", "false");
        if (adminModalOpen) adminModalOpen.setAttribute("aria-expanded", "true");
        document.body.classList.add("overflow-hidden");
      };

      const closeAdminModal = () => {
        if (!adminModal) return;
        adminModal.classList.add("hidden");
        adminModal.setAttribute("aria-hidden", "true");
        if (adminModalOpen) adminModalOpen.setAttribute("aria-expanded", "false");
        document.body.classList.remove("overflow-hidden");
      };

      if (adminModalOpen) {
        adminModalOpen.addEventListener("click", openAdminModal);
      }

      if (adminModalClose) {
        adminModalClose.addEventListener("click", closeAdminModal);
      }

      if (adminModal) {
        adminModal.addEventListener("click", (event) => {
          if (event.target.closest("[data-admin-close]")) {
            closeAdminModal();
          }
        });
      }

      if (adminNewBtn && adminDetails) {
        adminNewBtn.addEventListener("click", () => {
          closeAdminModal();
          adminDetails.classList.remove("hidden");
          adminDetails.scrollIntoView({ behavior: "smooth", block: "start" });
        });
      }

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          closeAdminModal();
        }
      });

      const REGISTRATION_KEY = "restaurant_accounts_v1";
      const ADMIN_LAST_KEY = "admin_last_key_v1";
      const registrationForm = document.getElementById("registration-form");

      const normalizeLabelText = (label) => label.textContent.replace(/\s+/g, " ").trim();

      const getFieldByLabel = (labelText) => {
        if (!registrationForm) return null;
        const labels = Array.from(registrationForm.querySelectorAll("label"));
        const match = labels.find((label) => normalizeLabelText(label).startsWith(labelText));
        return match ? match.querySelector("input, select") : null;
      };

      const safeJsonParse = (value, fallback = []) => {
        if (!value) return fallback;
        try {
          return JSON.parse(value);
        } catch (error) {
          return fallback;
        }
      };

      const readStorage = (key) => {
        try {
          return localStorage.getItem(key);
        } catch (error) {
          return null;
        }
      };

      const writeStorage = (key, value) => {
        try {
          localStorage.setItem(key, value);
        } catch (error) {
          // Storage can be blocked in file:// or privacy modes.
        }
      };

      const clearValidityOnInput = (field) => {
        if (!field) return;
        field.addEventListener("input", () => field.setCustomValidity(""));
        field.addEventListener("change", () => field.setCustomValidity(""));
      };

      if (registrationForm) {
        const emailField = getFieldByLabel("Email");
        const phoneField = getFieldByLabel("Phone");
        const accessKeyField = getFieldByLabel("Owner Access Key");
        const passwordField = getFieldByLabel("Password");
        const confirmField = getFieldByLabel("Confirm Password");
        const termsField = getFieldByLabel("I agree");
        const ACTIVE_RESTAURANT_KEY = "active_restaurant_key_v1";

        clearValidityOnInput(emailField);
        clearValidityOnInput(phoneField);
        clearValidityOnInput(accessKeyField);
        clearValidityOnInput(passwordField);
        clearValidityOnInput(confirmField);
        clearValidityOnInput(termsField);

        const normalizeEmail = (value) => value.trim().toLowerCase();
        const normalizeAccessKey = (value) => value.trim().replace(/\s+/g, "").toUpperCase();
        const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

        if (emailField) {
          emailField.addEventListener("input", () => {
            emailField.value = emailField.value.replace(/\s+/g, "");
          });
        }

        if (phoneField) {
          phoneField.addEventListener("input", () => {
            const digits = phoneField.value.replace(/\D/g, "").slice(0, 10);
            if (phoneField.value !== digits) {
              phoneField.value = digits;
            }
          });
        }

        if (accessKeyField) {
          accessKeyField.addEventListener("input", () => {
            accessKeyField.value = accessKeyField.value.replace(/\s+/g, "").toUpperCase();
          });
        }

        registrationForm.addEventListener("submit", (event) => {
          event.preventDefault();

          if (!registrationForm.reportValidity()) return;

          const emailValue = emailField ? normalizeEmail(emailField.value) : "";
          if (emailField && !emailPattern.test(emailValue)) {
            emailField.setCustomValidity("Please enter a valid email address.");
            emailField.reportValidity();
            return;
          }

          const phoneValue = phoneField ? phoneField.value.replace(/\D/g, "") : "";
          if (phoneField && phoneValue.length !== 10) {
            phoneField.setCustomValidity("Please enter a 10-digit phone number.");
            phoneField.reportValidity();
            return;
          }

          const accessKeyValue = accessKeyField ? normalizeAccessKey(accessKeyField.value) : "";
          if (accessKeyField && !accessKeyValue) {
            accessKeyField.setCustomValidity("Please create an owner access key.");
            accessKeyField.reportValidity();
            return;
          }

          const password = passwordField ? passwordField.value.trim() : "";
          const confirmPassword = confirmField ? confirmField.value.trim() : "";

          if (passwordField && confirmField && password !== confirmPassword) {
            confirmField.setCustomValidity("Passwords do not match.");
            confirmField.reportValidity();
            return;
          }

          if (termsField && !termsField.checked) {
            termsField.setCustomValidity("Please accept the terms to continue.");
            termsField.reportValidity();
            return;
          }

          const restaurantName = getFieldByLabel("Restaurant Name")?.value.trim() || "";
          const ownerName = getFieldByLabel("Owner Name")?.value.trim() || "";
          const email = emailValue;
          const phone = phoneValue;
          const city = getFieldByLabel("City")?.value.trim() || "";
          const cuisine = getFieldByLabel("Cuisine Type")?.value.trim() || "";
          const capacity = getFieldByLabel("Seating Capacity")?.value.trim() || "";

          const accounts = safeJsonParse(readStorage(REGISTRATION_KEY), []);
          const accessKey = accessKeyValue;
          const keyTaken = accounts.some(
            (account) =>
              (account.accessKey || "").toUpperCase() === accessKey && (account.email || "").toLowerCase() !== email
          );

          if (keyTaken && accessKeyField) {
            accessKeyField.setCustomValidity("This access key is already in use. Please choose another.");
            accessKeyField.reportValidity();
            return;
          }

          const accountData = {
            accessKey,
            restaurantName,
            ownerName,
            email,
            phone,
            city,
            cuisine,
            capacity,
            password,
            createdAt: Date.now()
          };

          const existingIndex = accounts.findIndex((account) => (account.email || "").toLowerCase() === email);

          if (existingIndex >= 0) {
            accounts[existingIndex] = {
              ...accounts[existingIndex],
              ...accountData,
              updatedAt: Date.now()
            };
          } else {
            accounts.push(accountData);
          }

          writeStorage(REGISTRATION_KEY, JSON.stringify(accounts));
          writeStorage(ADMIN_LAST_KEY, accessKey);
          writeStorage(ACTIVE_RESTAURANT_KEY, accessKey);
          writeStorage(
            "admin_session_v1",
            JSON.stringify({
              key: accessKey,
              restaurantName,
              ownerName,
              email,
              phone,
              loggedInAt: Date.now()
            })
          );

          window.location.href = "../owner_builder/code.html";
        });
      }
    </script>
  </body>
</html>


