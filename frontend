<!DOCTYPE html>
<html class="dark" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Panel | Restaurant Suite</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet" />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
    <link href="styles.css" rel="stylesheet" />
    <script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              primary: "#f28c28",
              "background-light": "#f6f2ea",
              "background-dark": "#0f1a18"
            },
            fontFamily: {
              display: ["Manrope"]
            },
            borderRadius: {
              DEFAULT: "0.5rem",
              lg: "1rem",
              xl: "1.5rem",
              full: "9999px"
            }
          }
        }
      };
    </script>
  </head>
  <body
    class="bg-background-light text-slate-900 min-h-screen dark:bg-gradient-to-b dark:from-[#152421] dark:via-[#0f1a18] dark:to-[#0b1412] dark:text-slate-100 font-display"
  >
    <div class="relative flex min-h-screen w-full flex-col overflow-x-hidden">
      <div class="layout-container flex h-full grow flex-col">
        <!-- Top Navigation Bar -->
        <header
          class="flex items-center justify-between whitespace-nowrap border-b border-primary/20 bg-background-light px-6 py-4 dark:bg-background-dark md:px-20 lg:px-40"
        >
          <div class="flex items-center gap-8">
            <div class="flex items-center gap-3 text-primary">
              <span class="material-symbols-outlined text-3xl">restaurant_menu</span>
              <h2 class="text-lg font-bold leading-tight tracking-tight text-slate-900 dark:text-slate-100">Restaurant Suite</h2>
            </div>
            <nav class="hidden items-center gap-8 md:flex">
              <a
                class="text-sm font-medium text-slate-600 transition-colors hover:text-primary dark:text-slate-400"
                href="../menu_section/code.html"
              >
                Dashboard
              </a>
              <a class="border-b-2 border-primary pb-1 text-sm font-semibold text-primary" href="../menu_management/code.html">
                Menu
              </a>
              <a
                class="text-sm font-medium text-slate-600 transition-colors hover:text-primary dark:text-slate-400"
                href="../bill_payment/code.html"
              >
                Orders
              </a>
              <a
                class="text-sm font-medium text-slate-600 transition-colors hover:text-primary dark:text-slate-400"
                href="../menu_section/code.html"
              >
                Staff
              </a>
            </nav>
          </div>
          <div class="flex flex-1 items-center justify-end gap-6">
            <label
              class="hidden h-10 w-full max-w-xs items-stretch rounded-xl border border-slate-300 bg-slate-200 dark:border-primary/20 dark:bg-primary/10 lg:flex"
            >
              <div class="flex items-center justify-center pl-4 text-slate-500 dark:text-primary/60">
                <span class="material-symbols-outlined">search</span>
              </div>
              <input
                class="w-full border-none bg-transparent text-sm placeholder:text-slate-500 focus:ring-0 dark:placeholder:text-primary/40"
                id="admin-search"
                placeholder="Search menu items..."
              />
            </label>
            <select
              class="hidden h-10 rounded-xl border border-primary/20 bg-slate-200 px-3 text-sm font-semibold text-slate-600 dark:bg-primary/10 dark:text-primary lg:block"
              id="admin-filter"
            >
              <option value="All">All Categories</option>
              <option value="Starters">Starters</option>
              <option value="Main Course">Main Course</option>
              <option value="Breads">Breads</option>
              <option value="Rice">Rice</option>
              <option value="Beverages">Beverages</option>
              <option value="Desserts">Desserts</option>
            </select>
            <span
              class="hidden items-center gap-2 rounded-full border border-primary/30 bg-primary/10 px-3 py-1 text-xs font-semibold text-primary lg:inline-flex"
            >
              <span class="material-symbols-outlined text-sm">admin_panel_settings</span>
              Admin Panel
            </span>
          </div>
        </header>

        <main class="flex flex-1 justify-center py-8 px-4 md:px-20 lg:px-40">
          <div class="layout-content-container flex w-full max-w-6xl flex-col gap-8">
            <!-- Header Section -->
            <div class="flex flex-wrap items-end justify-between gap-4">
              <div class="flex flex-col gap-1">
                <h1 class="text-4xl font-black tracking-tight text-slate-900 dark:text-slate-100">Menu Inventory</h1>
                <p class="text-lg text-slate-600 dark:text-primary/60">Manage your signature dishes and live availability.</p>
              </div>
              <button
                class="flex items-center gap-2 rounded-xl bg-primary px-6 py-3 font-bold text-background-dark shadow-lg shadow-primary/20 transition-all hover:bg-primary/90"
                id="admin-add-toggle"
              >
                <span class="material-symbols-outlined">add_circle</span>
                <span>Add Menu Item</span>
              </button>
            </div>

            <!-- Add Item Form -->
            <section class="hidden rounded-2xl border border-primary/20 bg-primary/5 p-6" id="admin-add-form">
              <div class="mb-4 flex items-center justify-between">
                <div>
                  <h2 class="text-xl font-bold">Add New Menu Item</h2>
                  <p class="text-sm text-slate-500 dark:text-primary/60">All items should be vegetarian/Jain.</p>
                </div>
                <button
                  class="rounded-lg border border-primary/30 px-3 py-1 text-xs font-semibold text-primary hover:bg-primary/10"
                  id="admin-add-close"
                  type="button"
                >
                  Close
                </button>
              </div>
              <form class="grid grid-cols-1 gap-4 md:grid-cols-2" id="admin-item-form">
                <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700 dark:text-primary/70">
                  Dish Name
                  <input
                    class="h-11 rounded-xl border border-primary/20 bg-white px-4 text-sm focus:border-primary focus:ring-primary dark:bg-background-dark"
                    id="admin-name"
                    placeholder="e.g. Paneer Bhurji Jain"
                    required
                  />
                </label>
                <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700 dark:text-primary/70">
                  Category
                  <select
                    class="h-11 rounded-xl border border-primary/20 bg-white px-4 text-sm focus:border-primary focus:ring-primary dark:bg-background-dark"
                    id="admin-category"
                  >
                    <option>Starters</option>
                    <option>Main Course</option>
                    <option>Breads</option>
                    <option>Rice</option>
                    <option>Beverages</option>
                    <option>Desserts</option>
                  </select>
                </label>
                <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700 dark:text-primary/70">
                  Price (&#8377;)
                  <input
                    class="h-11 rounded-xl border border-primary/20 bg-white px-4 text-sm focus:border-primary focus:ring-primary dark:bg-background-dark"
                    id="admin-price"
                    min="0"
                    placeholder="e.g. 220"
                    type="number"
                    required
                  />
                </label>
                <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700 dark:text-primary/70">
                  Image URL
                  <input
                    class="h-11 rounded-xl border border-primary/20 bg-white px-4 text-sm focus:border-primary focus:ring-primary dark:bg-background-dark"
                    id="admin-image"
                    placeholder="https://..."
                  />
                </label>
                <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700 dark:text-primary/70 md:col-span-2">
                  Description
                  <input
                    class="h-11 rounded-xl border border-primary/20 bg-white px-4 text-sm focus:border-primary focus:ring-primary dark:bg-background-dark"
                    id="admin-description"
                    placeholder="Short Jain-friendly description"
                    required
                  />
                </label>
                <label class="flex items-center gap-2 text-sm font-semibold text-slate-700 dark:text-primary/70">
                  <input class="h-4 w-4 rounded border-primary/40 text-primary" id="admin-available" type="checkbox" checked />
                  Available Today
                </label>
                <div class="flex items-end md:col-span-2">
                  <button
                    class="h-11 w-full rounded-xl bg-primary font-bold text-background-dark shadow-lg shadow-primary/20 transition-all hover:bg-primary/90"
                    type="submit"
                  >
                    Save Item
                  </button>
                </div>
              </form>
            </section>

            <!-- Luxury Table Layout -->
            <div
              class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-xl shadow-black/5 dark:border-primary/20 dark:bg-background-dark/50"
            >
              <table class="w-full border-collapse text-left">
                <thead>
                  <tr class="border-b border-slate-200 bg-slate-50 dark:border-primary/20 dark:bg-primary/5">
                    <th class="px-6 py-5 text-sm font-bold uppercase tracking-wider text-slate-500 dark:text-primary/70">
                      Item Details
                    </th>
                    <th class="px-6 py-5 text-sm font-bold uppercase tracking-wider text-slate-500 dark:text-primary/70">
                      Category
                    </th>
                    <th class="px-6 py-5 text-sm font-bold uppercase tracking-wider text-slate-500 dark:text-primary/70">
                      Price (&#8377;)
                    </th>
                    <th
                      class="px-6 py-5 text-center text-sm font-bold uppercase tracking-wider text-slate-500 dark:text-primary/70"
                    >
                      Availability
                    </th>
                    <th
                      class="px-6 py-5 text-right text-sm font-bold uppercase tracking-wider text-slate-500 dark:text-primary/70"
                    >
                      Actions
                    </th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-primary/10" id="admin-menu-body"></tbody>
              </table>
            </div>

            <!-- Pagination / Status Footer -->
            <div class="flex flex-wrap items-center justify-between gap-4 py-2">
              <div class="flex flex-col gap-1">
                <p class="text-sm text-slate-500 dark:text-primary/50" id="admin-count">Showing 0 of 0 menu items</p>
                <p class="text-xs text-primary/60 opacity-0 transition-opacity" id="admin-status">Saved.</p>
              </div>
              <div class="flex items-center gap-2" id="admin-pagination"></div>
            </div>

            <!-- Quick Update Section -->
            <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-100 p-6 dark:border-primary/10 dark:bg-primary/5">
              <div class="mb-6 flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">edit_square</span>
                <h2 class="text-xl font-bold">Batch Item Update</h2>
              </div>
              <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
                <label class="flex flex-col gap-2">
                  <span class="text-sm font-semibold text-slate-600 dark:text-primary/70">Category Modifier</span>
                  <select
                    class="h-12 rounded-xl border-slate-300 bg-white px-4 text-sm focus:border-primary focus:ring-primary dark:border-primary/20 dark:bg-background-dark"
                  >
                    <option>Select category...</option>
                    <option>Appetizer</option>
                    <option>Main Course</option>
                    <option>Desserts</option>
                  </select>
                </label>
                <label class="flex flex-col gap-2">
                  <span class="text-sm font-semibold text-slate-600 dark:text-primary/70">Price Surcharge (%)</span>
                  <input
                    class="h-12 rounded-xl border-slate-300 bg-white px-4 text-sm focus:border-primary focus:ring-primary dark:border-primary/20 dark:bg-background-dark"
                    placeholder="e.g. 5"
                    type="number"
                  />
                </label>
                <div class="flex items-end">
                  <button
                    class="h-12 w-full rounded-xl border border-primary/30 bg-slate-800 font-bold text-white transition-all hover:bg-primary hover:text-background-dark dark:bg-primary/20 dark:text-primary"
                  >
                    Apply Changes
                  </button>
                </div>
              </div>
            </div>
          </div>
        </main>

        <!-- Bottom Navigation (Mobile Only) -->
        <nav class="sticky bottom-0 flex items-center justify-around border-t border-primary/20 bg-background-light py-3 dark:bg-background-dark md:hidden">
          <a class="flex flex-col items-center gap-1 text-slate-400" href="../menu_section/code.html">
            <span class="material-symbols-outlined">dashboard</span>
            <span class="text-[10px]">Home</span>
          </a>
          <a class="flex flex-col items-center gap-1 text-primary" href="../menu_management/code.html">
            <span class="material-symbols-outlined">restaurant_menu</span>
            <span class="text-[10px]">Menu</span>
          </a>
          <a class="flex flex-col items-center gap-1 text-slate-400" href="../bill_payment/code.html">
            <span class="material-symbols-outlined">shopping_bag</span>
            <span class="text-[10px]">Orders</span>
          </a>
          <a class="flex flex-col items-center gap-1 text-slate-400" href="../menu_section/code.html">
            <span class="material-symbols-outlined">settings</span>
            <span class="text-[10px]">Settings</span>
          </a>
        </nav>
      </div>
    </div>
    <script>
      const MENU_STORAGE_KEY = "menu_custom_v1";
      const REMOVED_STORAGE_KEY = "menu_removed_v1";
      const ACTIVE_RESTAURANT_KEY = "active_restaurant_key_v1";

      const adminTable = document.getElementById("admin-menu-body");
      const adminCount = document.getElementById("admin-count");
      const adminStatus = document.getElementById("admin-status");
      const adminSearch = document.getElementById("admin-search");
      const adminFilter = document.getElementById("admin-filter");
      const addToggle = document.getElementById("admin-add-toggle");
      const addForm = document.getElementById("admin-add-form");
      const addClose = document.getElementById("admin-add-close");
      const itemForm = document.getElementById("admin-item-form");
      const adminPagination = document.getElementById("admin-pagination");

      const ITEMS_PER_PAGE = 8;
      let currentPage = 1;

      const safeJsonParse = (value, fallback = []) => {
        if (!value) return fallback;
        try {
          return JSON.parse(value);
        } catch (error) {
          return fallback;
        }
      };

      const readStorage = (key) => {
        try {
          return localStorage.getItem(key);
        } catch (error) {
          return null;
        }
      };

      const getKeySlug = (value) =>
        String(value || "")
          .trim()
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, "-")
          .replace(/^-|-$/g, "");

      const getMenuStorageKey = (key) => {
        const slug = getKeySlug(key);
        return slug ? `menu_builder_${slug}` : "menu_builder_v1";
      };

      let baseItems = [];
      let customItems = safeJsonParse(readStorage(MENU_STORAGE_KEY), []);
      let removedIds = new Set(safeJsonParse(readStorage(REMOVED_STORAGE_KEY), []));
      let allItems = [];
      let filteredItems = [];

      const slugify = (value) => value.toLowerCase().replace(/\s+/g, "-");
      const formatPrice = (value) => `₹${value}`;

      const updateFilterOptions = (categories = []) => {
        if (!adminFilter) return;
        const current = adminFilter.value || "All";
        const unique = Array.from(new Set(categories.filter(Boolean)));
        adminFilter.innerHTML = [
          `<option value="All">All Categories</option>`,
          ...unique.map((category) => `<option value="${category}">${category}</option>`)
        ].join("");
        if (unique.includes(current)) {
          adminFilter.value = current;
        } else {
          adminFilter.value = "All";
        }
      };

      const showStatus = (message) => {
        if (!adminStatus) return;
        adminStatus.textContent = message;
        adminStatus.classList.remove("opacity-0");
        adminStatus.classList.add("opacity-100");
        window.setTimeout(() => {
          adminStatus.classList.add("opacity-0");
        }, 2000);
      };

      const buildRow = (item) => `
        <tr>
          <td class="px-6 py-5">
            <div class="flex items-center gap-4">
              <div class="size-12 overflow-hidden rounded-xl border border-primary/20 bg-slate-100 dark:bg-primary/10">
                <img class="h-full w-full object-cover" src="${item.image}" alt="${item.name}" />
              </div>
              <div>
                <p class="text-sm font-semibold text-slate-900 dark:text-slate-100">${item.name}</p>
                <p class="text-xs text-slate-500 dark:text-primary/60">${item.description}</p>
              </div>
            </div>
          </td>
          <td class="px-6 py-5 text-sm text-slate-600 dark:text-primary/70">${item.category}</td>
          <td class="px-6 py-5 text-sm font-semibold text-slate-900 dark:text-slate-100">${formatPrice(item.price)}</td>
          <td class="px-6 py-5 text-center">
            <label class="inline-flex items-center gap-2 text-xs font-semibold text-slate-500 dark:text-primary/70">
              <input
                class="h-4 w-4 rounded border-primary/30 text-primary"
                type="checkbox"
                data-action="toggle"
                data-id="${item.id}"
                ${item.available ? "checked" : ""}
              />
              ${item.available ? "Available" : "Unavailable"}
            </label>
          </td>
          <td class="px-6 py-5 text-right">
            <button
              class="rounded-lg border border-primary/30 px-3 py-1 text-xs font-semibold text-primary hover:bg-primary/10"
              data-action="remove"
              data-id="${item.id}"
              type="button"
            >
              Remove
            </button>
          </td>
        </tr>
      `;

      const renderTable = (items, totalCount, startIndex) => {
        if (!adminTable) return;
        adminTable.innerHTML = items.map(buildRow).join("");
        if (adminCount) {
          if (!totalCount) {
            adminCount.textContent = "Showing 0 of 0 menu items";
          } else {
            const start = startIndex + 1;
            const end = Math.min(startIndex + items.length, totalCount);
            adminCount.textContent = `Showing ${start}-${end} of ${totalCount} menu items`;
          }
        }
      };

      const renderPagination = (totalPages) => {
        if (!adminPagination) return;
        adminPagination.innerHTML = "";

        const baseClass =
          "flex size-10 items-center justify-center rounded-xl bg-slate-200 text-slate-600 transition-all hover:bg-primary hover:text-background-dark dark:bg-primary/10 dark:text-primary";
        const activeClass = "flex size-10 items-center justify-center rounded-xl bg-primary font-bold text-background-dark";
        const disabledClass = "opacity-50 cursor-not-allowed";

        const makeButton = (label, onClick, options = {}) => {
          const button = document.createElement("button");
          button.type = "button";
          button.className = options.active ? activeClass : baseClass;
          if (options.icon) {
            const icon = document.createElement("span");
            icon.className = "material-symbols-outlined";
            icon.textContent = options.icon;
            button.appendChild(icon);
          } else {
            button.textContent = label;
          }
          if (options.disabled) {
            button.disabled = true;
            button.classList.add(...disabledClass.split(" "));
          } else {
            button.addEventListener("click", onClick);
          }
          adminPagination.appendChild(button);
        };

        makeButton("Prev", () => {
          currentPage = Math.max(1, currentPage - 1);
          paginateItems();
        }, { icon: "chevron_left", disabled: currentPage === 1 });

        for (let page = 1; page <= totalPages; page += 1) {
          makeButton(String(page), () => {
            currentPage = page;
            paginateItems();
          }, { active: page === currentPage });
        }

        makeButton("Next", () => {
          currentPage = Math.min(totalPages, currentPage + 1);
          paginateItems();
        }, { icon: "chevron_right", disabled: currentPage === totalPages });
      };

      const paginateItems = () => {
        const totalCount = filteredItems.length;
        const totalPages = Math.max(1, Math.ceil(totalCount / ITEMS_PER_PAGE));
        currentPage = Math.min(currentPage, totalPages);
        const startIndex = (currentPage - 1) * ITEMS_PER_PAGE;
        const pageItems = filteredItems.slice(startIndex, startIndex + ITEMS_PER_PAGE);
        renderTable(pageItems, totalCount, startIndex);
        renderPagination(totalPages);
      };

      const applyFilters = (resetPage = false) => {
        const term = adminSearch ? adminSearch.value.trim().toLowerCase() : "";
        const categoryFilter = adminFilter ? adminFilter.value : "All";
        filteredItems = allItems.filter((item) => {
          const matchesTerm = term
            ? item.name.toLowerCase().includes(term) || item.category.toLowerCase().includes(term)
            : true;
          const matchesCategory = categoryFilter === "All" ? true : item.category === categoryFilter;
          return matchesTerm && matchesCategory;
        });
        if (resetPage) {
          currentPage = 1;
        }
        paginateItems();
      };

      const getBuilderMenu = () => {
        const activeKey = readStorage(ACTIVE_RESTAURANT_KEY);
        if (!activeKey) return null;
        const stored = readStorage(getMenuStorageKey(activeKey));
        const parsed = safeJsonParse(stored, null);
        if (!parsed || !Array.isArray(parsed.items)) {
          return { categories: [], items: [] };
        }

        const categories =
          Array.isArray(parsed.categories) && parsed.categories.length
            ? parsed.categories
            : Array.from(new Set(parsed.items.map((item) => item.category).filter(Boolean)));

        const items = parsed.items.map((item, index) => ({
          id: item.id || `builder-${index + 1}`,
          category: item.category || categories[0] || "Menu",
          name: item.name || "Menu Item",
          description: item.description || "Chef curated vegetarian favorite",
          price: Number(String(item.price).replace(/[^0-9.]/g, "")) || 0,
          image: item.image || "../images/menu/veg_biryani.jpg",
          available: item.available !== false,
          isCustom: false
        }));

        return { categories, items };
      };

      const loadMenuData = async () => {
        const builderMenu = getBuilderMenu();
        if (builderMenu) {
          baseItems = builderMenu.items;
          updateFilterOptions(builderMenu.categories);
          baseItems = baseItems.filter((item) => !removedIds.has(item.id));
          allItems = baseItems.concat(customItems);
          applyFilters(true);
          return;
        }

        const menuResponse = await fetch("../menu_data.json");
        const data = await menuResponse.json();
        const categories = Object.keys(data);
        baseItems = categories.flatMap((category) =>
          data[category].map((item, index) => ({
            id: `${slugify(category)}-${index + 1}`,
            category,
            name: item.name,
            description: "Chef curated vegetarian favorite",
            price: Number(item.price.toString().replace(/[^0-9.]/g, "")),
            image: item.image,
            available: true,
            isCustom: false
          }))
        );

        updateFilterOptions(categories);
        baseItems = baseItems.filter((item) => !removedIds.has(item.id));
        allItems = baseItems.concat(customItems);
        applyFilters(true);
      };

      if (addToggle && addForm) {
        addToggle.addEventListener("click", () => {
          addForm.classList.remove("hidden");
        });
      }

      if (addClose && addForm) {
        addClose.addEventListener("click", () => {
          addForm.classList.add("hidden");
        });
      }

      if (itemForm) {
        itemForm.addEventListener("submit", (event) => {
          event.preventDefault();
          const name = document.getElementById("admin-name").value.trim();
          const category = document.getElementById("admin-category").value;
          const price = Number(document.getElementById("admin-price").value);
          const imageInput = document.getElementById("admin-image").value.trim();
          const description = document.getElementById("admin-description").value.trim();
          const available = document.getElementById("admin-available").checked;

          if (!name || Number.isNaN(price)) return;

          const newItem = {
            id: `custom-${Date.now()}`,
            category,
            name,
            description: description || "Custom menu addition",
            price,
            image: imageInput || "../images/menu/veg_biryani.jpg",
            available,
            isCustom: true
          };

          customItems.push(newItem);
          localStorage.setItem(MENU_STORAGE_KEY, JSON.stringify(customItems));
          allItems = baseItems.concat(customItems);
          updateFilterOptions(allItems.map((item) => item.category));
          applyFilters(true);
          itemForm.reset();
          addForm.classList.add("hidden");
          showStatus("Saved.");
        });
      }

      if (adminSearch) {
        adminSearch.addEventListener("input", () => applyFilters(true));
      }

      if (adminFilter) {
        adminFilter.addEventListener("change", () => applyFilters(true));
      }

      if (adminTable) {
        adminTable.addEventListener("click", (event) => {
          const button = event.target.closest("button[data-action]");
          if (!button) return;
          const action = button.dataset.action;
          const id = button.dataset.id;
          if (!id) return;

          if (action === "remove") {
            removedIds.add(id);
            localStorage.setItem(REMOVED_STORAGE_KEY, JSON.stringify(Array.from(removedIds)));
            customItems = customItems.filter((item) => item.id !== id);
            localStorage.setItem(MENU_STORAGE_KEY, JSON.stringify(customItems));
            baseItems = baseItems.filter((item) => item.id !== id);
            allItems = baseItems.concat(customItems);
            updateFilterOptions(allItems.map((item) => item.category));
            applyFilters();
            showStatus("Removed.");
          }
        });

        adminTable.addEventListener("change", (event) => {
          const checkbox = event.target.closest("input[data-action='toggle']");
          if (!checkbox) return;
          const id = checkbox.dataset.id;
          const item = allItems.find((entry) => entry.id === id);
          if (item) {
            item.available = checkbox.checked;
            applyFilters();
          }
        });
      }

      loadMenuData();
    </script>
  </body>
</html>


